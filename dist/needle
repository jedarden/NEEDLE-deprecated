# Count existing alternatives for a HUMAN bead
# Returns: Number of existing alternative beads
_needle_unravel_count_alternatives() {
    local workspace="$1"
    local parent_id="$2"

    local count
    # FIX (nd-mme0): br list does not support --workspace flag. Must cd to workspace.
    count=$(cd "$workspace" 2>/dev/null && br list --label "for-$parent_id" --json 2>/dev/null | jq 'length' 2>/dev/null || echo "0")

    echo "$count"
