# Allow running this module directly for testing
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    case "${1:-}" in
        run)
            if [[ -z "${2:-}" ]] || [[ -z "${3:-}" ]]; then
                echo "Usage: $0 run <workspace> <agent>"
                exit 1
            fi
            # Set up environment for testing
            NEEDLE_SESSION="test-session"
