# NEEDLE Global Configuration Template
# Copy to ~/.needle/config.yaml and customize for your environment.
#
# Configuration Hierarchy:
#   1. ~/.needle/config.yaml   — Global defaults and limits (this file)
#   2. .needle.yaml            — Per-workspace overrides (in workspace root)
#   3. CLI flags               — Per-invocation overrides
#
# All duration values accept suffixes: s (seconds), m (minutes), h (hours), d (days)
# Example: 30s, 5m, 2h, 1d

# ============================================================================
# Billing Model
# ============================================================================
# Controls how NEEDLE optimizes work relative to API cost.
#
# Models:
#   pay_per_token  — Conservative: minimize spend, respect budgets strictly
#   use_or_lose    — Aggressive: maximize utilization of subscription quota
#   unlimited      — Local inference (ollama): no cost constraints
billing:
  # default_model: Billing model profile
  #   - pay_per_token: Conservative (default), minimize token usage
  #   - use_or_lose: Aggressive, use allocated budget
  #   - unlimited: Maximum throughput, no budget enforcement
  default_model: pay_per_token

  # Per-provider billing overrides
  providers:
    anthropic: pay_per_token    # API billing
    openai: pay_per_token       # API billing
    alibaba: use_or_lose        # Monthly subscription with quota
    zai: use_or_lose            # Monthly subscription with quota
    ollama: unlimited           # Local inference

# ============================================================================
# Effort Tracking and Budgets
# ============================================================================
# Tracks token usage, cost, and enforces spending limits.
effort:
  # log_dir: Directory for effort tracking logs
  log_dir: ~/.needle/logs

  # budget: Spending limits and enforcement
  budget:
    # daily_limit_usd: Stop spawning workers when daily spend exceeds this amount
    daily_limit_usd: 50.0

    # warning_threshold: Warn when spending reaches this percentage of limit (0.0-1.0)
    warning_threshold: 0.8       # Warn at 80% of limit

    # per_bead_limit_usd: Maximum spend for a single bead execution
    per_bead_limit_usd: 5.0

# ============================================================================
# Concurrency Limits
# ============================================================================
# Prevent overwhelming API rate limits or local hardware resources.
# Provider limits apply to all models from that provider.
# Model limits override provider limits for specific models.
limits:
  # Global ceiling across all workers regardless of provider/model
  global_max_concurrent: 20

  # Per-provider concurrency and rate limits
  providers:
    anthropic:
      max_concurrent: 5         # Max concurrent workers using any Anthropic model
      requests_per_minute: 60   # API rate limit (0 = unlimited)
    openai:
      max_concurrent: 3
      requests_per_minute: 60
    alibaba:
      max_concurrent: 10
    ollama:
      max_concurrent: 2         # Local inference — limited by GPU/CPU capacity

  # Per-model overrides (take precedence over provider limits)
  models:
    claude-anthropic-opus:
      max_concurrent: 2         # Opus is expensive; limit concurrent use
      requests_per_minute: 20
    claude-anthropic-sonnet:
      max_concurrent: 5
    opencode-ollama-deepseek:
      max_concurrent: 1         # Single local GPU

# ============================================================================
# Runner
# ============================================================================
# Controls bead polling behavior and idle handling for all workers.
runner:
  polling_interval: 2s          # How often workers check for new beads
  idle_timeout: 300s            # Shut down worker after being idle this long (0 = never)

# ============================================================================
# Session Naming
# ============================================================================
# Pattern for tmux session names. Available placeholders:
#   {runner}      — CLI executable type: claude, opencode, codex, aider
#   {provider}    — API provider: anthropic, openai, alibaba, zai, ollama
#   {model}       — Model identifier: sonnet, opus, gpt4, deepseek
#   {identifier}  — Unique worker suffix: alpha, bravo, charlie, ...
naming:
  pattern: "needle-{runner}-{provider}-{model}-{identifier}"

# ============================================================================
# Strands
# ============================================================================
# Strands are an ordered list of work-finding strategies. Position = priority.
# Presence = enabled. Remove from list to disable.
#
# Relative paths resolve against the NEEDLE installation directory.
#
# Built-in strands:
#   pluck    — Claim OPEN beads from configured workspaces (always on)
#   explore  — Discover work in adjacent workspaces (low overhead)
#   mend     — Maintenance: clean logs, recover stale heartbeats
#   weave    — Create beads from documentation gaps (opt-in)
#   unravel  — Generate alternative approaches for blocked beads (opt-in)
#   pulse    — Codebase health monitoring, auto-generate fix beads (opt-in)
#   knot     — Alert the human when workers are stuck
strands:
  - strands/pluck.sh     # Primary work from configured workspaces
  - strands/explore.sh   # Look for work in other workspaces
  - strands/mend.sh      # Maintenance and cleanup
  # - strands/weave.sh   # Create beads from documentation gaps (opt-in)
  # - strands/unravel.sh # Create alternatives for blocked beads (opt-in)
  # - strands/pulse.sh   # Codebase health monitoring (opt-in)
  - strands/knot.sh      # Alert human when stuck

# ============================================================================
# Mend Strand Configuration
# ============================================================================
# Maintenance strand that cleans up stale resources.
mend:
  # heartbeat_max_age: Seconds before a stale heartbeat is considered dead
  heartbeat_max_age: 3600       # Default: 1 hour

  # max_log_files: Maximum number of log files to keep
  max_log_files: 100

  # min_interval: Minimum seconds between mend runs
  min_interval: 60

# ============================================================================
# Hooks
# ============================================================================
# User-defined scripts executed at lifecycle events. Each hook receives
# environment variables describing the current bead and worker state.
#
# Hook exit codes:
#   0   — Success (continue normally)
#   1   — Warning (log warning but continue)
#   2   — Abort (stop current operation)
#   3   — Skip (skip remaining hooks for this event)
#   124 — Timeout (hook exceeded timeout limit)
#
# Hook points (all optional):
#   pre_claim      — Before NEEDLE attempts to claim a bead
#   post_claim     — After a bead is successfully claimed
#   pre_execute    — Before the worker agent starts on a bead
#   post_execute   — After the worker agent finishes (any outcome)
#   pre_complete   — Before marking a bead as complete
#   post_complete  — After a bead is marked complete
#   on_failure     — When a bead fails or is quarantined
#   on_quarantine  — When a bead is explicitly quarantined
#   pre_commit     — Before committing work (git operations)
#   post_task      — After the full bead lifecycle ends
#   error_recovery — When NEEDLE attempts to recover from an error
hooks:
  # timeout: Maximum time a hook can run
  timeout: 30s

  # fail_action: What to do when a hook exits non-zero
  #   warn   — Log warning and continue (default)
  #   abort  — Stop the current operation
  #   ignore — Silently ignore hook failures
  fail_action: warn

  # Hook scripts (uncomment and set paths to enable)
  # pre_claim:     ~/.needle/hooks/pre-claim.sh
  # post_claim:    ~/.needle/hooks/post-claim.sh
  # pre_execute:   ~/.needle/hooks/pre-execute.sh
  # post_execute:  ~/.needle/hooks/post-execute.sh
  # pre_complete:  ~/.needle/hooks/pre-complete.sh
  # post_complete: ~/.needle/hooks/post-complete.sh
  # on_failure:    ~/.needle/hooks/on-failure.sh
  # on_quarantine: ~/.needle/hooks/on-quarantine.sh
  # pre_commit:    ~/.needle/hooks/pre-commit.sh
  # post_task:     ~/.needle/hooks/post-task.sh
  # error_recovery: ~/.needle/hooks/error-recovery.sh

# ============================================================================
# Mitosis
# ============================================================================
# Controls automatic bead splitting. When enabled, complex beads can be
# split into smaller child beads by the worker before starting execution.
mitosis:
  # enabled: Enable/disable mitosis globally
  enabled: true

  # skip_types: Bead types that should not be split (comma-separated)
  skip_types: bug,hotfix

  # skip_labels: Labels that prevent mitosis (comma-separated)
  skip_labels: no-mitosis,atomic

  # max_children: Maximum number of children per mitosis
  max_children: 5

  # min_children: Minimum children required to perform mitosis
  min_children: 2

  # min_complexity: Minimum number of files/concerns before considering mitosis
  min_complexity: 3

  # timeout: Timeout in seconds for mitosis analysis
  timeout: 60

# ============================================================================
# Knot Strand Configuration
# ============================================================================
# Human alerts when workers are stuck. The knot strand notifies humans
# when beads remain blocked for extended periods.
knot:
  # rate_limit_interval: Minimum seconds between stuck alerts per workspace
  rate_limit_interval: 3600     # Default: 1 hour

# ============================================================================
# Weave Strand Configuration
# ============================================================================
# Documentation gap detection. This strand analyzes documentation and
# creates beads to fill gaps. Opt-in only (disabled by default).
weave:
  # frequency: Minimum seconds between weave runs per workspace
  frequency: 3600               # Default: 1 hour

  # max_beads_per_run: Maximum beads to create per weave analysis
  max_beads_per_run: 5

  # max_doc_files: Maximum documentation files to analyze per run
  max_doc_files: 50

# ============================================================================
# Unravel Strand Configuration
# ============================================================================
# Alternative approaches for blocked HUMAN beads. This strand proposes
# alternative solutions when human-assigned beads are stuck. Opt-in only.
unravel:
  # min_wait_hours: Hours a HUMAN bead must wait before alternatives proposed
  min_wait_hours: 24

  # max_alternatives: Maximum alternative beads to create per HUMAN bead
  max_alternatives: 3

  # timeout: Timeout in seconds for unravel analysis
  timeout: 120

# ============================================================================
# Watchdog (Heartbeat)
# ============================================================================
# Monitors worker health via heartbeat signals. Workers that stop sending
# heartbeats are assumed stuck and can be automatically recovered.
watchdog:
  # interval: Seconds between heartbeat checks
  interval: 30

  # heartbeat_timeout: Seconds without a heartbeat before worker is considered stuck
  heartbeat_timeout: 120

  # bead_timeout: Maximum seconds a bead can run before forced recovery
  bead_timeout: 600             # Default: 10 minutes

  # recovery_action: Action when a stuck worker is detected
  #   restart — Attempt to respawn the worker after recovery
  #   stop    — Just kill the worker without respawning
  recovery_action: restart

  # startup_grace: Seconds to wait before enforcing heartbeat checks on new workers
  startup_grace: 60

# ============================================================================
# Pulse Strand Configuration
# ============================================================================
# Codebase health monitoring. This strand scans for security issues,
# outdated dependencies, stale TODOs, and documentation drift.
# Opt-in only (disabled by default in strands list).
pulse:
  # frequency: Minimum time between pulse scans
  frequency: 24h

  # max_beads_per_run: Maximum beads to create per scan
  max_beads_per_run: 5

  # seen_issues_retention_days: Days to remember seen issues for deduplication
  seen_issues_retention_days: 30

  # coverage_threshold: Minimum test coverage percentage
  coverage_threshold: 70

  # todo_age_days: Days before a TODO is considered stale
  todo_age_days: 180

  # max_todos_per_run: Maximum stale TODOs to report per scan
  max_todos_per_run: 10

  # stale_threshold_days: Days before a dependency is considered stale
  stale_threshold_days: 365

  # max_deps_per_run: Maximum stale dependencies to report per scan
  max_deps_per_run: 10

  # detectors: Enable/disable specific health detectors
  detectors:
    security: true              # Scan for security vulnerabilities
    dependencies: true          # Check for outdated dependencies
    docs: true                  # Check for documentation drift
    doc_drift_enabled: true     # Enable documentation reference drift detection
    coverage: false             # Monitor test coverage trends
    todos: true                 # Detect stale TODO/FIXME comments

# ============================================================================
# Work Stealing (Select)
# ============================================================================
# Allows idle workers to claim beads assigned to inactive assignees.
# This ensures work doesn't stall when workers become unavailable.
select:
  # work_stealing_enabled: Enable/disable work stealing
  work_stealing_enabled: true

  # work_stealing_timeout: Seconds before an assigned bead becomes stealable
  work_stealing_timeout: 1800   # Default: 30 minutes

  # stealable_assignees: List of assignee names whose beads can be stolen
  # "coder" is the human user - their beads become stealable when stale
  stealable_assignees:
    - coder

  # check_worker_heartbeat: Also check if assignee worker has no heartbeat
  check_worker_heartbeat: true

  # unassigned_by_default: Leave new beads unassigned for workers to claim
  # When true, beads created by NEEDLE are immediately released after creation
  unassigned_by_default: true

  # === Advanced Work Stealing (Idle Worker Features) ===

  # proactive_stealing_enabled: Enable proactive work stealing by idle workers
  proactive_stealing_enabled: true

  # stealing_load_threshold: Min claimed beads before worker is "overloaded"
  stealing_load_threshold: 2

  # stealing_idle_threshold: Seconds of idle time before worker can steal
  stealing_idle_threshold: 60

  # stealing_priority_boost: Priority weight multiplier for stolen beads
  stealing_priority_boost: 1

  # steal_from_active_workers: Allow stealing from workers with heartbeats
  # WARNING: This can cause duplicate work if workers are actually processing
  steal_from_active_workers: false

# ============================================================================
# Scaling
# ============================================================================
# Controls automatic worker spawn behavior when the bead backlog grows.
scaling:
  spawn_threshold: 3            # Spawn a new worker when open bead count exceeds N
  max_workers_per_agent: 10     # Hard ceiling on concurrent workers per agent type
  cooldown_seconds: 30          # Minimum seconds between consecutive spawn attempts

# ============================================================================
# File Locks
# ============================================================================
# Controls file locking behavior to prevent concurrent workers from writing
# to the same files simultaneously.
file_locks:
  # timeout: Maximum time a lock can be held before it is considered stale
  timeout: 30m

  # stale_action: What to do when a stale lock is detected
  #   warn    — Log warning but keep the lock (default)
  #   release — Force-release the stale lock
  #   ignore  — Do not check for stale locks
  stale_action: warn

  # strategy: Locking strategy for concurrent file access
  #   pessimistic — Acquire exclusive lock before reading/writing (default)
  #   optimistic  — Write without locking; detect and merge conflicts after
  strategy: pessimistic

  # ld_preload: Intercept filesystem calls via LD_PRELOAD for deeper lock coverage
  # Provides hard enforcement for agents without native hook support (OpenCode, Aider)
  ld_preload: false

  # ld_preload_lib: Path to the LD_PRELOAD shared library (required if ld_preload: true)
  # Build with: ./scripts/build-native.sh
  # Default: ~/.needle/lib/libcheckout.so
  # ld_preload_lib: ~/.needle/lib/libcheckout.so

  # Merge settings (applies when strategy: optimistic)
  merge:
    enabled: false              # Enable automatic merge on optimistic conflict
    tool: git-merge-file        # Merge tool: git-merge-file | diff3 | custom
    on_conflict: block          # Action when merge fails: block | keep_ours | keep_theirs

  # Lease settings for lock renewal
  lease:
    # duration: How long a lock lease is valid before requiring renewal
    duration: 5m

    # renewal_interval: How often to renew the lease while holding the lock
    renewal_interval: 30s

    # grace_period: Extra time allowed for renewal before lock is stale
    grace_period: 1m

# ============================================================================
# FABRIC Telemetry
# ============================================================================
# Forwards stream-json events to FABRIC dashboard for live visualization.
fabric:
  # enabled: Enable/disable FABRIC event forwarding
  enabled: false

  # endpoint: FABRIC API endpoint URL (can also use FABRIC_ENDPOINT env var)
  # Example: http://localhost:3000/api/events
  endpoint: ""

  # timeout: HTTP request timeout in seconds
  timeout: 2

  # batching: Enable event batching to reduce HTTP overhead
  batching: false

# ============================================================================
# Bug Scanner
# ============================================================================
# Integrates ultimate_bug_scanner (UBS) as a quality gate before beads are
# marked complete. UBS catches 1000+ bug patterns across popular languages
# and is designed for AI agent integration.
#
# Severity levels (lowest to highest): info, warning, error, critical
#
# Install UBS: needle bootstrap --dep ubs
bug_scanner:
  enabled: true                 # Enable/disable bug scanning
  severity_threshold: error     # Minimum severity that triggers a failure
  fail_on_issues: true          # Fail the bead if issues exceed threshold
  create_follow_up: true        # Create a follow-up bugfix bead when issues are found
  timeout: 300                  # Seconds before scan is aborted
  output_format: json           # Scan output format
  preflight_check: false        # Run a quick critical-only check before agent dispatch

# ============================================================================
# Debug
# ============================================================================
# Automatic bug bead creation for unexpected errors during NEEDLE operation.
# When enabled, creates bug beads in a configured workspace when errors occur.
#
# Error types that trigger auto bead creation:
#   quarantine   — Error escalation is "quarantine" (unrecoverable errors)
#   unregistered — Error event type is not in the error registry
#
# Auto beads are rate-limited by error signature to prevent bead floods.
debug:
  auto_bead_on_error: false     # Enable/disable auto bead creation
  auto_bead_workspace: ""       # Workspace path where auto beads are created (required if enabled)
  auto_bead_types:              # Error types that trigger auto bead creation
    - quarantine                #   - quarantine: errors with escalation=quarantine
    - unregistered              #   - unregistered: unknown/unregistered error types
  auto_bead_rate_limit: 3600    # Minimum seconds between duplicate filings (default: 1 hour)

# ============================================================================
# Updates
# ============================================================================
# Automatic NEEDLE binary update checking and installation.
updates:
  check_on_startup: true        # Check for updates when needle starts
  check_interval: 24h           # Background check interval (0 = disable background checks)
  auto_upgrade: false           # Automatically install updates without prompting
  include_prereleases: false    # Include pre-release versions in update checks
  disabled: false               # Set true to disable all update checking
